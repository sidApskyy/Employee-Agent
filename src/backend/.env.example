# Server
PORT=3000
NODE_ENV=production
API_URL=http://YOUR_SERVER_IP:3000

# Database (PostgreSQL / Supabase)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/rdcs_agent

# JWT — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Amazon S3 (backend only — never expose to desktop client)
S3_BUCKET_NAME=rdcs-employee-screenshots
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Seeding
COMPANY_ID=company-rdcs-001
SEED_DEFAULT_PASSWORD=Change@Me2024!

# Agent config served to desktop clients
CONFIG_VERSION=1.0.0
AGENT_VERSION=1.0.0
AGENT_RETRY_COUNT=3
AGENT_TIMEOUT_SECONDS=30
AGENT_LOG_LEVEL=Information
HEARTBEAT_INTERVAL_SECONDS=60

# Feature flags (true/false)
FEATURE_SCREENSHOTS=true
FEATURE_APP_MONITORING=false
FEATURE_WEBSITE_MONITORING=false
FEATURE_IDLE_DETECTION=false
FEATURE_USB_MONITORING=false
