<Window x:Class="RDCS.EmployeeAgent.UI.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RDCS Employee Agent"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="#2C3E50" 
                CornerRadius="8" 
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="RDCS Employee Agent" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="{Binding EmployeeName, StringFormat='Employee: {0}'}" 
                               FontSize="12" 
                               Foreground="#BDC3C7"
                               Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding DeviceName, StringFormat='Device: {0}'}" 
                               FontSize="12" 
                               Foreground="#BDC3C7"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse Width="12" Height="12" 
                             Fill="#2ECC71"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"
                             Visibility="{Binding IsOnline, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Ellipse Width="12" Height="12" 
                             Fill="#E74C3C"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"
                             Visibility="{Binding IsOnline, Converter={StaticResource InverseBooleanConverter}}"/>
                    <TextBlock Text="{Binding Status}" 
                               FontSize="12" 
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="8" 
                Padding="20">
            <Grid>
                <TextBlock Text="Agent Dashboard" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Modules will be displayed here in future iterations" 
                           FontSize="14" 
                           Foreground="#7F8C8D"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,40,0,0"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Settings" 
                    Command="{Binding ShowSettingsCommand}"
                    Margin="0,0,10,0"
                    Padding="10,5"
                    Background="#95A5A6"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Logout" 
                    Command="{Binding LogoutCommand}"
                    Padding="10,5"
                    Background="#E74C3C"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
